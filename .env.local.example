# Supabase PostgreSQL connection string (Project Settings > Database > Connection string > URI)
# Use the "Transaction" pooler URL (port 6543) for Vercel
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# JWT secret — generate a random 32+ char string
SECRET_KEY=change-me-to-a-long-random-secret

# Seed protection — used to call /api/admin/seed
SEED_SECRET=another-random-secret
